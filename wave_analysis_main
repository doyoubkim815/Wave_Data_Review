# 4. Common Utility Functions
# =========================================================
def normalize_columns(df: pd.DataFrame) -> pd.DataFrame:
    """
    컬럼명을 정규화한다.

    목적
    - 대소문자 차이 제거
    - 공백 / 특수문자 차이 완화

    예
    - ' Time Local ' -> 'time_local'
    - 'Depth(m)'     -> 'depth_m'
    - 'wind speed'   -> 'wind_speed'
    """
    original_cols = list(df.columns)

    normalized = []
    for col in original_cols:
        c = str(col).strip().lower()
        c = c.replace(" ", "_")
        c = c.replace("-", "_")
        c = c.replace("/", "_")
        c = c.replace("(", "")
        c = c.replace(")", "")
        c = c.replace(".", "_")
        while "__" in c:
            c = c.replace("__", "_")
        normalized.append(c)

    df = df.copy()
    df.columns = normalized
    return df


def ensure_time_axis(df: pd.DataFrame, cfg: Config) -> Tuple[pd.DataFrame, Dict, pd.DataFrame]:
    """
    분석용 공통 시간축 analysis_time 을 생성한다.

    설계 원칙
    - 현재 raw 데이터 구조에서는 time_local이 날짜+시각+소수초를 포함하므로
      이를 주 분석 시간축으로 사용한다.

    반환
    - df
    - time_meta
    """
    df = df.copy()
    df["raw_row_index"] = df.index

    # -----------------------------------------------------
    # 1) 숫자형 컬럼 변환
    # 수치 연산이 필요한 컬럼은 미리 숫자형으로 변환
    # -----------------------------------------------------
    numeric_cols = [cfg.depth_col, cfg.wind_dir_col, cfg.wind_speed_col]
    for col in numeric_cols:
        if col in df.columns:
            df[col] = pd.to_numeric(df[col], errors="coerce")

    # -----------------------------------------------------
    # 2) time_local 필수 확인 및 파싱
    # -----------------------------------------------------
    if cfg.time_col not in df.columns:
        raise KeyError(
            f"필수 시간 컬럼 '{cfg.time_col}' 이 없습니다. "
            "현재 데이터 구조에서는 time_local을 주 시간축으로 사용합니다."
        )

    parsed_time_local = pd.to_datetime(df[cfg.time_col], errors="coerce")
    valid_ratio = parsed_time_local.notna().mean()

    if valid_ratio <= 0.95:
        raise ValueError(
            f"time_local 파싱 실패 비율이 높습니다. "
            f"(유효 비율: {valid_ratio:.3f})"
        )

    # analysis_time 생성
    df["analysis_time"] = parsed_time_local

    # -----------------------------------------------------
    # 3) 처리 제외 규칙 마스크 생성
    # - invalid_time: analysis_time 파싱 실패
    # - invalid_depth: depth_m 결측/0.0
    # - duplicate_time: 유효 시간/유효 depth 대상 중 중복 analysis_time (첫 행 제외)
    # -----------------------------------------------------
    invalid_time_mask = df["analysis_time"].isna()

    if cfg.depth_col not in df.columns:
        raise KeyError(f"필수 컬럼이 없습니다: {cfg.depth_col}")
    invalid_depth_mask = df[cfg.depth_col].isna() | (df[cfg.depth_col] == 0)

    eligible_for_duplicate = (~invalid_time_mask) & (~invalid_depth_mask)
    duplicate_time_mask = pd.Series(False, index=df.index)

    dedup_target = df.loc[eligible_for_duplicate].sort_values(
        by=["analysis_time", "raw_row_index"],
        kind="mergesort",
    )
    duplicated_in_target = dedup_target.duplicated(subset=["analysis_time"], keep="first")
    duplicate_time_mask.loc[dedup_target.index] = duplicated_in_target

    excluded_mask = invalid_time_mask | invalid_depth_mask | duplicate_time_mask

    # -----------------------------------------------------
    # 4) 처리 제외 raw 행 구성 (중복 사유 동시 표기)
    # -----------------------------------------------------
    excluded_rows_df = df.loc[excluded_mask].copy()
    excluded_rows_df["excluded_by_invalid_time"] = invalid_time_mask.loc[excluded_rows_df.index]
    excluded_rows_df["excluded_by_duplicate_time"] = duplicate_time_mask.loc[excluded_rows_df.index]
    excluded_rows_df["excluded_by_invalid_depth"] = invalid_depth_mask.loc[excluded_rows_df.index]

    def _join_reasons(row) -> str:
        reasons = []
        if row["excluded_by_invalid_time"]:
            reasons.append("invalid_time")
        if row["excluded_by_duplicate_time"]:
            reasons.append("duplicate_analysis_time")
        if row["excluded_by_invalid_depth"]:
            reasons.append("invalid_depth_missing_or_zero")
        return ";".join(reasons)

    excluded_rows_df["exclusion_reason"] = excluded_rows_df.apply(_join_reasons, axis=1)
    excluded_rows_df["exclusion_reason_count"] = (
        excluded_rows_df[[
            "excluded_by_invalid_time",
            "excluded_by_duplicate_time",
            "excluded_by_invalid_depth",
        ]].sum(axis=1)
    )

    # -----------------------------------------------------
    # 5) 유효 데이터만 유지 후 시간순 정렬
    # -----------------------------------------------------
    df = df.loc[~excluded_mask].copy()
    df = df.sort_values(by=["analysis_time", "raw_row_index"], kind="mergesort").reset_index(drop=True)

    # -----------------------------------------------------
    # 6) 시간축 메타정보 정리
    # -----------------------------------------------------
    multi_reason_rows = int((excluded_rows_df["exclusion_reason_count"] > 1).sum()) if not excluded_rows_df.empty else 0

    time_meta = {
        "time_axis_source": "time_local",
        "analysis_time_start": str(df["analysis_time"].min()),
        "analysis_time_end": str(df["analysis_time"].max()),
        "pre_clean_rows_dropped_due_to_invalid_time": int(invalid_time_mask.sum()),
        "pre_clean_rows_dropped_due_to_duplicate_time": int(duplicate_time_mask.sum()),
        "pre_clean_rows_dropped_due_to_invalid_depth": int(invalid_depth_mask.sum()),
        "pre_clean_rows_excluded_total_unique": int(excluded_mask.sum()),
        "pre_clean_rows_excluded_with_multiple_reasons": multi_reason_rows,
    }

    return df.drop(columns=["raw_row_index"]), time_meta, excluded_rows_df.reset_index(drop=True)


def make_output_dir(file_path: Path, cfg: Config) -> Path:
    """
    입력 파일명 기준으로 출력 폴더를 생성한다.

    예
    - 입력: C:/data/raw_01.xlsx
    - 출력: ./outputs/raw_01/
    """
    out_root = Path(cfg.output_root)
    out_dir = out_root / file_path.stem
    out_dir.mkdir(parents=True, exist_ok=True)
    return out_dir


def log_meta(results: AnalysisResults, section: str, info: Dict):
    """
    각 모듈별 메타정보를 results.meta에 저장한다.

    예
    - results.meta["load_input"] = {...}
    - results.meta["timebase_qa"] = {...}
    """
    results.meta[section] = info


# =========================================================
# 5. Pre-processing Modules
# 현재는 골격만 유지. 이후 기능 추가 시 이 함수 내부만 구현.
# =========================================================
def run_timebase_qa(df: pd.DataFrame, cfg: Config) -> Tuple[pd.DataFrame, Dict]:
    """
    시간축 품질 점검 모듈

    현재 구현
    - 실제 dt 분포 계산
    - 기대 dt(0.1s) 대비 편차
    - gap / duplicate / missing 구간 진단
    - 시간축 품질 메타정보 출력
    """
    if "analysis_time" not in df.columns:
        raise KeyError("run_timebase_qa() 실행을 위해 'analysis_time' 컬럼이 필요합니다.")

    qa_meta = {
        "post_clean_expected_dt_sec": float(cfg.expected_dt_sec),
        "post_clean_n_rows": int(len(df)),
        "post_clean_n_intervals": 0,
        "post_clean_dt_mean_sec": None,
        "post_clean_dt_std_sec": None,
        "post_clean_dt_min_sec": None,
        "post_clean_dt_q05_sec": None,
        "post_clean_dt_median_sec": None,
        "post_clean_dt_q95_sec": None,
        "post_clean_dt_max_sec": None,
        "post_clean_dt_abs_diff_mean_sec": None,
        "post_clean_dt_abs_diff_max_sec": None,
        "post_clean_n_duplicate_intervals": 0,
        "post_clean_n_non_increasing_intervals": 0,
        "post_clean_n_gap_intervals": 0,
        "post_clean_gap_intervals": [],
        "gap_rows": [],
        "post_clean_estimated_missing_samples": 0,
        "post_clean_n_large_dt_deviation": 0,
    }

    if len(df) < 2:
        return df, qa_meta

    # -----------------------------------------------------
    # 1) dt 계산
    # -----------------------------------------------------
    work = df[["analysis_time"]].sort_values("analysis_time").reset_index(drop=True)
    dt_series = work["analysis_time"].diff().dt.total_seconds()
    dt_sec = dt_series.dropna()

    qa_meta["post_clean_n_intervals"] = int(len(dt_sec))

    # -----------------------------------------------------
    # 2) dt 분포 요약 통계
    # -----------------------------------------------------
    qa_meta["post_clean_dt_mean_sec"] = float(dt_sec.mean())
    qa_meta["post_clean_dt_std_sec"] = float(dt_sec.std(ddof=0))
    qa_meta["post_clean_dt_min_sec"] = float(dt_sec.min())
    qa_meta["post_clean_dt_q05_sec"] = float(dt_sec.quantile(0.05))
    qa_meta["post_clean_dt_median_sec"] = float(dt_sec.median())
    qa_meta["post_clean_dt_q95_sec"] = float(dt_sec.quantile(0.95))
    qa_meta["post_clean_dt_max_sec"] = float(dt_sec.max())

    # -----------------------------------------------------
    # 3) expected_dt 대비 편차 통계
    # -----------------------------------------------------
    expected_dt = float(cfg.expected_dt_sec)
    abs_diff = (dt_sec - expected_dt).abs()
    qa_meta["post_clean_dt_abs_diff_mean_sec"] = float(abs_diff.mean())
    qa_meta["post_clean_dt_abs_diff_max_sec"] = float(abs_diff.max())

    # -----------------------------------------------------
    # 4) gap / duplicate / missing 진단
    # -----------------------------------------------------
    duplicate_mask = dt_sec == 0
    non_increasing_mask = dt_sec <= 0
    gap_mask = dt_sec > expected_dt * 1.5
    large_deviation_mask = abs_diff > expected_dt * 0.5

    qa_meta["post_clean_n_duplicate_intervals"] = int(duplicate_mask.sum())
    qa_meta["post_clean_n_non_increasing_intervals"] = int(non_increasing_mask.sum())
    qa_meta["post_clean_n_gap_intervals"] = int(gap_mask.sum())
    qa_meta["post_clean_n_large_dt_deviation"] = int(large_deviation_mask.sum())

    gap_rows = dt_sec[gap_mask]
    gap_records = []
    for curr_idx, curr_dt in gap_rows.items():
        gap_records.append(
            {
                "index": int(curr_idx),
                "time": str(work.loc[curr_idx, "analysis_time"]),
                "dt_sec": float(curr_dt),
            }
        )
    qa_meta["post_clean_gap_intervals"] = gap_records
    qa_meta["gap_rows"] = gap_records

    if expected_dt > 0:
        estimated_missing = ((dt_sec[gap_mask] / expected_dt).round() - 1).clip(lower=0).sum()
        qa_meta["post_clean_estimated_missing_samples"] = int(estimated_missing)

    return df, qa_meta


def run_gap_handling(df: pd.DataFrame, cfg: Config, qa_meta: Dict) -> Tuple[pd.DataFrame, Dict]:
    """
    gap 구간 분류 모듈

    현재 구현
    - run_timebase_qa()의 gap_rows를 입력으로 받음
    - short gap / long gap 분류
    - 실제 보간/수정 없이 목록화만 수행
    """
    gap_rows = qa_meta.get("gap_rows", [])

    short_gap_rows = []
    long_gap_rows = []

    for row in gap_rows:
        dt_sec = row.get("dt_sec")

        if dt_sec is None:
            continue

        if dt_sec <= 0.3:
            short_gap_rows.append(row)
        else:
            long_gap_rows.append(row)

    gap_meta = {
        "short_gap_count": int(len(short_gap_rows)),
        "long_gap_count": int(len(long_gap_rows)),
        "short_gap_rows": short_gap_rows,
        "long_gap_rows": long_gap_rows,
    }

    return df, gap_meta


def run_depth_qc(df: pd.DataFrame, cfg: Config) -> Tuple[pd.DataFrame, Dict]:
    """
    depth_m 이상치 제거 모듈

    현재 구현
    - Hampel(rolling median + MAD) 기반 이상치 플래그
    - |d(depth)/dt| 물리 룰 기반 이상치 플래그
    - 보간/수정 없이 flag + exclude 후보 컬럼 생성
    """
    if cfg.depth_col not in df.columns:
        raise KeyError(f"run_depth_qc() 실행을 위해 '{cfg.depth_col}' 컬럼이 필요합니다.")

    def qc_despike_depth(
        depth: pd.Series,
        dt: float,
        method: str = "hampel",
        window_sec: float = 3.0,
        n_sigma: float = 6.0,
        max_slope_mps: float = 2.0,
    ) -> Tuple[pd.Series, pd.Series, pd.Series]:
        """
        depth 시계열의 이상치 후보를 탐지한다.

        반환
        - spike_mask_hampel
        - spike_mask_slope
        - rolling_median
        """
        if method != "hampel":
            raise ValueError("현재 depth QC는 method='hampel'만 지원합니다.")

        if dt <= 0:
            raise ValueError("dt는 0보다 커야 합니다.")

        # -------------------------------------------------
        # 1) Hampel 파라미터 계산
        # -------------------------------------------------
        window_n = max(3, int(round(window_sec / dt)))
        if window_n % 2 == 0:
            window_n += 1

        # -------------------------------------------------
        # 2) rolling median + MAD 기반 플래그
        # -------------------------------------------------
        rolling_median = depth.rolling(window=window_n, center=True, min_periods=1).median()
        abs_dev = (depth - rolling_median).abs()
        rolling_mad = abs_dev.rolling(window=window_n, center=True, min_periods=1).median()

        hampel_threshold = 1.4826 * rolling_mad * n_sigma
        spike_mask_hampel = (abs_dev > hampel_threshold).fillna(False)

        # -------------------------------------------------
        # 3) 물리 룰 기반 slope 플래그
        # -------------------------------------------------
        slope = (depth.diff().abs() / dt)
        spike_mask_slope = (slope > max_slope_mps).fillna(False)

        return spike_mask_hampel, spike_mask_slope, rolling_median

    df = df.copy()
    depth = pd.to_numeric(df[cfg.depth_col], errors="coerce")

    # -----------------------------------------------------
    # 1) dt 추정 (analysis_time 기반)
    # -----------------------------------------------------
    dt = float(cfg.expected_dt_sec)
    if "analysis_time" in df.columns and len(df) >= 2:
        dt_series = df["analysis_time"].sort_values().diff().dt.total_seconds().dropna()
        dt_series = dt_series[dt_series > 0]
        if not dt_series.empty:
            dt = float(dt_series.median())

    # -----------------------------------------------------
    # 2) 이상치 플래그 계산
    # -----------------------------------------------------
    spike_mask_hampel, spike_mask_slope, rolling_median = qc_despike_depth(
        depth=depth,
        dt=dt,
        method=cfg.depth_qc_method,
        window_sec=cfg.depth_qc_window_sec,
        n_sigma=cfg.depth_qc_n_sigma,
        max_slope_mps=cfg.depth_qc_max_slope_mps,
    )
    anomaly_mask = (spike_mask_hampel | spike_mask_slope)

    # -----------------------------------------------------
    # 3) isolated spike vs bad segment 구분 (plateau 과탐 완화)
    # -----------------------------------------------------
    bad_segment_min_duration_sec = 0.5
    bad_segment_max_duration_sec = 0.8

    run_id = (anomaly_mask != anomaly_mask.shift(1, fill_value=False)).cumsum()
    anomaly_groups = df.loc[anomaly_mask].groupby(run_id[anomaly_mask])

    depth_flag_spike = pd.Series(False, index=df.index)
    depth_flag_bad_segment = pd.Series(False, index=df.index)
    depth_flag_jump_recover = pd.Series(False, index=df.index)
    bad_segment_rows = []

    n_isolated_spikes = 0
    n_jump_recover_spikes = 0
    n_plateau_candidates = 0
    n_plateau_suppressed = 0

    plateau_tol = max(0.005, dt * cfg.depth_qc_max_slope_mps * 0.1)
    jump_mag_threshold = max(0.03, plateau_tol * 6)
    recovery_tol = max(0.01, plateau_tol * 3)

    for _, g in anomaly_groups:
        g_idx = g.index
        start_idx = int(g_idx.min())
        end_idx = int(g_idx.max())

        if "analysis_time" in df.columns:
            start_time = df.loc[start_idx, "analysis_time"]
            end_time = df.loc[end_idx, "analysis_time"]
            duration_sec = float((end_time - start_time).total_seconds())
        else:
            duration_sec = float(max(0.0, (len(g_idx) - 1) * dt))

        seg_depth = depth.loc[g_idx]
        seg_range = float((seg_depth.max() - seg_depth.min())) if seg_depth.notna().any() else 0.0
        is_plateau_like = seg_range <= plateau_tol
        if is_plateau_like:
            n_plateau_candidates += 1

        has_slope_flag = bool(spike_mask_slope.loc[g_idx].any())

        pre_v = depth.iloc[start_idx - 1] if start_idx > 0 else pd.NA
        post_v = depth.iloc[end_idx + 1] if end_idx < len(df) - 1 else pd.NA
        has_prepost = pd.notna(pre_v) and pd.notna(post_v)

        local_recovery = False
        if has_prepost:
            local_recovery = abs(float(pre_v - post_v)) <= recovery_tol

        jump_mag = 0.0
        if has_prepost and seg_depth.notna().any():
            jump_mag = float(max((seg_depth - float(pre_v)).abs().max(), (seg_depth - float(post_v)).abs().max()))
        elif seg_depth.notna().any():
            jump_mag = float((seg_depth.max() - seg_depth.min()))

        seg_diff = seg_depth.diff().dropna()
        is_discontinuous_glitch = False
        if not seg_diff.empty:
            big_jumps = (seg_diff.abs() >= jump_mag_threshold * 0.5)
            sign_flip = (seg_diff * seg_diff.shift(-1) < 0).fillna(False)
            is_discontinuous_glitch = bool(big_jumps.sum() >= 2 and sign_flip.any())

        # bad segment 승격: plateau가 아니고, 짧은 시간 내 jump/recover 또는 glitch 패턴일 때만 허용
        promote_bad_segment = (
            (not is_plateau_like)
            and has_slope_flag
            and (bad_segment_min_duration_sec <= duration_sec <= bad_segment_max_duration_sec)
            and (jump_mag >= jump_mag_threshold)
            and (local_recovery or is_discontinuous_glitch)
        )

        if promote_bad_segment:
            depth_flag_bad_segment.loc[g_idx] = True
            rec = {
                "start_index": start_idx,
                "end_index": end_idx,
                "n_rows": int(len(g_idx)),
                "duration_sec": duration_sec,
                "jump_mag": jump_mag,
                "local_recovery": bool(local_recovery),
                "is_discontinuous_glitch": bool(is_discontinuous_glitch),
            }
            if "analysis_time" in df.columns:
                rec["start_time"] = str(df.loc[start_idx, "analysis_time"])
                rec["end_time"] = str(df.loc[end_idx, "analysis_time"])
            bad_segment_rows.append(rec)
            continue

        # plateau/긴 계단 구간은 bad segment로 승격하지 않고, edge 1~2점만 spike 허용
        if is_plateau_like:
            n_plateau_suppressed += 1
            edge_candidates = []
            if bool(spike_mask_slope.loc[start_idx]):
                edge_candidates.append(start_idx)
            if bool(spike_mask_slope.loc[end_idx]) and end_idx != start_idx:
                edge_candidates.append(end_idx)
            if not edge_candidates and has_slope_flag:
                edge_candidates = [start_idx] if start_idx == end_idx else [start_idx, end_idx]

            for idx in edge_candidates[:2]:
                depth_flag_spike.loc[idx] = True
            if len(edge_candidates) == 1:
                n_isolated_spikes += 1
            continue

        # 그 외는 spike 후보 우선: 단일점/짧은 jump-recover 패턴
        if len(g_idx) == 1:
            depth_flag_spike.loc[g_idx] = True
            n_isolated_spikes += 1
        elif local_recovery and jump_mag >= jump_mag_threshold:
            for idx in list(g_idx)[:2]:
                depth_flag_spike.loc[idx] = True
                depth_flag_jump_recover.loc[idx] = True
                n_jump_recover_spikes += 1
        else:
            local_abs_dev = (depth.loc[g_idx] - rolling_median.loc[g_idx]).abs()
            rep_idx = int(local_abs_dev.fillna(-1).idxmax())
            depth_flag_spike.loc[rep_idx] = True

    # run_depth_qc는 탐지/판정만 수행하고, 실제 제외 마스크는 정책 함수에서 적용
    suggested_analysis_mask = (~depth_flag_bad_segment).astype(bool)

    df["depth_flag_spike"] = depth_flag_spike.astype(bool)
    df["depth_flag_bad_segment"] = depth_flag_bad_segment.astype(bool)
    df["depth_flag_jump_recover"] = depth_flag_jump_recover.astype(bool)
    df["depth_flag_hampel"] = spike_mask_hampel.astype(bool)
    df["depth_flag_slope"] = spike_mask_slope.astype(bool)

    # -----------------------------------------------------
    # 4) 메타정보 정리
    # -----------------------------------------------------
    slope_all = depth.diff().abs() / dt
    max_abs_slope = float(slope_all.max()) if slope_all.notna().any() else 0.0

    n_flagged_hampel = int(spike_mask_hampel.sum())
    n_flagged_slope = int(spike_mask_slope.sum())
    n_flagged_union = int(anomaly_mask.sum())

    n_hampel_only = int((spike_mask_hampel & ~spike_mask_slope).sum())
    n_slope_only = int((spike_mask_slope & ~spike_mask_hampel).sum())
    n_overlap_hampel_slope = int((spike_mask_hampel & spike_mask_slope).sum())
    spike_rate = float(n_flagged_union / len(df)) if len(df) > 0 else 0.0

    n_analysis_mask_false = int((~suggested_analysis_mask).sum())
    analysis_mask_false_rate = float(n_analysis_mask_false / len(df)) if len(df) > 0 else 0.0

    n_bad_segments_short = int(sum(1 for r in bad_segment_rows if r.get("duration_sec", 0.0) <= 0.3))
    n_bad_segments_long = int(sum(1 for r in bad_segment_rows if r.get("duration_sec", 0.0) > 0.3))

    depth_std_before = float(depth.std(skipna=True)) if depth.notna().any() else None
    kept_depth = depth[suggested_analysis_mask]
    depth_std_after = float(kept_depth.std(skipna=True)) if kept_depth.notna().any() else None
    if depth_std_before is None or depth_std_before == 0 or depth_std_after is None:
        depth_std_ratio = None
    else:
        depth_std_ratio = float(depth_std_after / depth_std_before)

    prev_depth = depth.shift(1)
    next_depth = depth.shift(-1)
    local_extrema_mask = ((depth > prev_depth) & (depth > next_depth)) | ((depth < prev_depth) & (depth < next_depth))
    local_extrema_near_mask = local_extrema_mask | local_extrema_mask.shift(1, fill_value=False) | local_extrema_mask.shift(-1, fill_value=False)
    if n_flagged_union > 0:
        extrema_flag_ratio = float((anomaly_mask & local_extrema_near_mask).sum() / n_flagged_union)
    else:
        extrema_flag_ratio = None

    qc_meta = {
        "n_flagged_spikes": n_flagged_union,
        "n_flagged_spikes_hampel": n_flagged_hampel,
        "n_flagged_spikes_slope": n_flagged_slope,
        "n_flagged_spikes_union": n_flagged_union,
        "n_hampel_only": n_hampel_only,
        "n_slope_only": n_slope_only,
        "n_overlap_hampel_slope": n_overlap_hampel_slope,
        "spike_rate": spike_rate,
        "n_analysis_mask_time_domain_false": n_analysis_mask_false,
        "analysis_mask_time_domain_false_rate": analysis_mask_false_rate,
        "n_bad_segments": int(len(bad_segment_rows)),
        "n_bad_segments_short": n_bad_segments_short,
        "n_bad_segments_long": n_bad_segments_long,
        "bad_segment_min_duration_sec": bad_segment_min_duration_sec,
        "n_isolated_spikes": int(n_isolated_spikes),
        "n_jump_recover_spikes": int(n_jump_recover_spikes),
        "n_plateau_candidates": int(n_plateau_candidates),
        "n_plateau_suppressed": int(n_plateau_suppressed),
        "n_bad_segments_after_plateau_filter": int(len(bad_segment_rows)),
        "bad_segment_rows": bad_segment_rows,
        "depth_std_before": depth_std_before,
        "depth_std_after": depth_std_after,
        "depth_std_ratio": depth_std_ratio,
        "extrema_flag_ratio": extrema_flag_ratio,
        "method": cfg.depth_qc_method,
        "window_sec": float(cfg.depth_qc_window_sec),
        "n_sigma": float(cfg.depth_qc_n_sigma),
        "max_slope_mps": float(cfg.depth_qc_max_slope_mps),
        "max_abs_slope": max_abs_slope,
    }

    return df, qc_meta


def apply_depth_exclusion_policy(df: pd.DataFrame, cfg: Config, qc_meta: Dict) -> Tuple[pd.DataFrame, Dict]:
    """
    Depth 제외 정책 적용 모듈

    목적
    - run_depth_qc()는 탐지/판정만 수행
    - 실제 analysis_mask_time_domain 제외는 정책 스위치로 적용
    """
    df = df.copy()

    flag_spike = df.get("depth_flag_spike", False).astype(bool)
    flag_bad_segment = df.get("depth_flag_bad_segment", False).astype(bool)
    flag_jump_recover = df.get("depth_flag_jump_recover", False).astype(bool)

    exclude_jump = flag_jump_recover if cfg.exclude_jump_recover_candidates else pd.Series(False, index=df.index)
    exclude_bad = flag_bad_segment if cfg.exclude_bad_segments else pd.Series(False, index=df.index)
    exclude_isolated = (
        flag_spike & (~flag_jump_recover) & (~flag_bad_segment)
        if cfg.exclude_isolated_spikes
        else pd.Series(False, index=df.index)
    )

    excluded_union = exclude_jump | exclude_bad | exclude_isolated
    analysis_mask_time_domain = (~excluded_union).astype(bool)
    df["analysis_mask_time_domain"] = analysis_mask_time_domain

    n_rows = len(df)
    n_excluded = int(excluded_union.sum())
    exclusion_meta = {
        "exclude_jump_recover_candidates": bool(cfg.exclude_jump_recover_candidates),
        "exclude_bad_segments": bool(cfg.exclude_bad_segments),
        "exclude_isolated_spikes": bool(cfg.exclude_isolated_spikes),
        "n_excluded_total": n_excluded,
        "excluded_rate_total": float(n_excluded / n_rows) if n_rows > 0 else 0.0,
        "n_excluded_jump_recover": int(exclude_jump.sum()),
        "n_excluded_bad_segments": int(exclude_bad.sum()),
        "n_excluded_isolated_spikes": int(exclude_isolated.sum()),
        "n_analysis_mask_time_domain_false": int((~analysis_mask_time_domain).sum()),
        "analysis_mask_time_domain_false_rate": float((~analysis_mask_time_domain).sum() / n_rows) if n_rows > 0 else 0.0,
    }

    return df, exclusion_meta


def run_detrend(df: pd.DataFrame, cfg: Config) -> Tuple[pd.DataFrame, Dict]:
    """
    기준수면 제거 모듈

    구현 내용
    - eta_centered: 평균 제거
    - eta_tide: 저주파(조석 성분)
    - eta_detrended: centered - tide
    - eta_short: 단주기 대역(기본 2~25s)
    - eta_ig: IG 대역(기본 25~300s)

    필터 우선순위
    1) scipy.signal (butter + filtfilt/sosfilt)
    2) 실패 시 rolling 기반 fallback
    """
    df = df.copy()

    if cfg.depth_col not in df.columns:
        raise KeyError(f"필수 컬럼이 없습니다: {cfg.depth_col}")

    depth = pd.to_numeric(df[cfg.depth_col], errors="coerce")
    if not depth.notna().any():
        raise ValueError("depth 시계열이 모두 결측입니다.")

    dt_sec = float(cfg.expected_dt_sec)
    if "analysis_time" in df.columns and len(df) >= 2:
        dt = df["analysis_time"].diff().dt.total_seconds()
        dt = dt[(dt > 0) & dt.notna()]
        if not dt.empty:
            dt_sec = float(dt.median())

    fs = 1.0 / dt_sec if dt_sec > 0 else 1.0
    nyq = 0.5 * fs

    eta_centered = depth - depth.mean(skipna=True)

    tide_cutoff_sec = float(cfg.detrend_tide_cutoff_sec)
    short_band_sec = (float(cfg.detrend_short_band_sec[0]), float(cfg.detrend_short_band_sec[1]))
    ig_band_sec = (float(cfg.detrend_ig_band_sec[0]), float(cfg.detrend_ig_band_sec[1]))

    filter_method = "rolling_fallback"

    def _rolling_lowpass(s: pd.Series, cutoff_sec: float) -> pd.Series:
        win = max(3, int(round(cutoff_sec / dt_sec)))
        if win % 2 == 0:
            win += 1
        return s.rolling(window=win, center=bool(cfg.detrend_zero_phase), min_periods=1).mean()

    def _rolling_bandpass(s: pd.Series, band_sec: Tuple[float, float]) -> pd.Series:
        p_min, p_max = sorted(band_sec)
        # 고역통과(느린 성분 제거)
        slow = _rolling_lowpass(s, p_max)
        hp = s - slow
        # 저역통과(너무 빠른 성분 완화)
        return _rolling_lowpass(hp, p_min)

    eta_tide = _rolling_lowpass(eta_centered, tide_cutoff_sec)
    eta_detrended = eta_centered - eta_tide
    eta_short = _rolling_bandpass(eta_detrended, short_band_sec)
    eta_ig = _rolling_bandpass(eta_detrended, ig_band_sec)

    try:
        from scipy import signal

        def _to_numpy_filled(s: pd.Series) -> np.ndarray:
            return s.interpolate(limit_direction="both").fillna(0.0).to_numpy(dtype=float)

        def _apply_sos(sos, x: np.ndarray) -> np.ndarray:
            if cfg.detrend_zero_phase:
                return signal.sosfiltfilt(sos, x)
            return signal.sosfilt(sos, x)

        x = _to_numpy_filled(eta_centered)

        # 저역통과(조석)
        tide_fc = 1.0 / tide_cutoff_sec
        tide_fc = min(max(tide_fc, 1e-9), nyq * 0.95)
        sos_tide = signal.butter(4, tide_fc, btype="lowpass", fs=fs, output="sos")
        eta_tide_np = _apply_sos(sos_tide, x)
        eta_detrended_np = x - eta_tide_np

        def _band_period_to_freq(period_band_sec: Tuple[float, float]) -> Tuple[float, float]:
            p1, p2 = sorted(period_band_sec)
            # period가 길수록 저주파
            low_f = 1.0 / p2
            high_f = 1.0 / p1
            low_f = min(max(low_f, 1e-9), nyq * 0.95)
            high_f = min(max(high_f, low_f * 1.05), nyq * 0.98)
            return low_f, high_f

        short_f = _band_period_to_freq(short_band_sec)
        ig_f = _band_period_to_freq(ig_band_sec)

        sos_short = signal.butter(4, short_f, btype="bandpass", fs=fs, output="sos")
        sos_ig = signal.butter(4, ig_f, btype="bandpass", fs=fs, output="sos")

        eta_short_np = _apply_sos(sos_short, eta_detrended_np)
        eta_ig_np = _apply_sos(sos_ig, eta_detrended_np)

        eta_tide = pd.Series(eta_tide_np, index=df.index)
        eta_detrended = pd.Series(eta_detrended_np, index=df.index)
        eta_short = pd.Series(eta_short_np, index=df.index)
        eta_ig = pd.Series(eta_ig_np, index=df.index)
        filter_method = "scipy.signal.butter+sosfiltfilt" if cfg.detrend_zero_phase else "scipy.signal.butter+sosfilt"

    except Exception:
        # scipy 미설치/필터 실패 시 rolling fallback 유지
        pass

    df["eta_centered"] = eta_centered
    df["eta_tide"] = eta_tide
    df["eta_detrended"] = eta_detrended
    df["eta_short"] = eta_short
    df["eta_ig"] = eta_ig

    detrend_meta = {
        "dt_sec": float(dt_sec),
        "tide_cutoff_sec": tide_cutoff_sec,
        "short_band_sec": [short_band_sec[0], short_band_sec[1]],
        "ig_band_sec": [ig_band_sec[0], ig_band_sec[1]],
        "zero_phase": bool(cfg.detrend_zero_phase),
        "filter_method": filter_method,
    }

    return df, detrend_meta


