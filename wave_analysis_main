        print(f"- 분석 시작 시각: {load_meta.get('analysis_time_start')}")
        print(f"- 분석 종료 시각: {load_meta.get('analysis_time_end')}")
        print(f"- 원본 행 수: {load_meta.get('raw_n_rows')}")
        print(f"- 처리 행 수: {load_meta.get('processed_n_rows')}")

        raw_n_rows = load_meta.get("raw_n_rows")
        processed_n_rows = load_meta.get("processed_n_rows")
        dropped_invalid_time = load_meta.get("pre_clean_rows_dropped_due_to_invalid_time", 0)
        dropped_duplicate_time = load_meta.get("pre_clean_rows_dropped_due_to_duplicate_time", 0)
        dropped_invalid_depth = load_meta.get("pre_clean_rows_dropped_due_to_invalid_depth", 0)
        excluded_unique = load_meta.get("pre_clean_rows_excluded_total_unique", 0)
        excluded_multi_reason = load_meta.get("pre_clean_rows_excluded_with_multiple_reasons", 0)

        if isinstance(raw_n_rows, int) and isinstance(processed_n_rows, int):
            excluded_n_rows = raw_n_rows - processed_n_rows
            print(f"- 입력 정리(pre-clean) 제외 행 수(총): {excluded_n_rows}")
            print(f"- 입력 정리(pre-clean) 제외 행 수(고유): {excluded_unique}")
            print("  · 제외 근거(대략):")
