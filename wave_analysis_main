def main():
    """
    프로그램 시작점

    현재 단계 동작
    - 입력 파일 경로 받기
    - 출력 폴더 생성
    - 파일 로드 및 시간축 생성
    - metadata 저장
    - 요약 콘솔 출력
    """
    cfg = Config()

    try:
        # 1) 입력 파일 선택
        file_path = prompt_input_file()

        # 2) 출력 폴더 생성
        out_dir = make_output_dir(file_path, cfg)

        # 3) 파이프라인 실행
        results = run_pipeline(file_path, cfg, out_dir)

        # 4) 메타정보 저장
        save_meta(results, out_dir)

        # 5) 콘솔 요약 출력
        load_meta = results.meta.get("load_input", {})

        print("\n[완료]")
        print(f"- 입력 파일: {file_path}")
        print(f"- 출력 폴더: {out_dir}")
