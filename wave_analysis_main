#!/usr/bin/env python3
# -*- coding: utf-8 -*-

"""
파고계 기반 파랑 분석 프레임워크 (기준 골격 v1)

목적
- csv / xlsx raw 데이터에서 파랑 분석을 단계적으로 확장하기 위한 단일 파일 골격
- 기능을 한 번에 다 넣지 않고, 이후 대화 또는 Codex를 통해 분석 항목을 하나씩 추가
- 코드 구조를 고정하여 추후 수정/추가 시 전체 형태가 흔들리지 않도록 함

현재 구현 범위
1) 입력 파일 경로 받기
2) csv / xlsx 파일 읽기
3) 컬럼명 정규화
4) time_local 기반 공통 시간축 생성
5) 출력 폴더 생성
6) metadata 저장

향후 추가 예정
- 시간축 QA (dt, gap, duplicate, missing)
- depth 이상치 제거(QC / despike)
- 기준수면 제거(detrend)
- 개별 파 검출(zero-crossing)
- Hs / Hmax / Tz sliding window 통계
- Hm0 / Tp / Tm01 / Tm02
- Sea / Swell 분리
- 장주기파(IG) 지표
- 이벤트 탐지
- 예보 비교 및 성능 평가
"""

# =========================================================
# 0. Imports
# =========================================================
import json
from pathlib import Path
from dataclasses import dataclass, field
from typing import Dict, Optional, Tuple

import pandas as pd


# =========================================================
# 1. User Config
# =========================================================
@dataclass
class Config:
    """
    사용자 설정값 모음

    원칙
    - 향후 제어변수는 모두 이 클래스에만 추가
    - 함수 내부에 하드코딩하지 않음
    """

    # -----------------------------------------------------
    # 1-1. 입력 파일 표준 컬럼명
    # -----------------------------------------------------
    time_col: str = "time_local"          # 주 분석 시간축 컬럼
    depth_col: str = "depth_m"            # 수면 높이 또는 수심 계측값
    wind_dir_col: str = "wind_dir_deg"    # 풍향 (현재는 읽기만 함)
    wind_speed_col: str = "wind_speed"    # 풍속 (현재는 읽기만 함)

    # -----------------------------------------------------
    # 1-2. 샘플링 관련
    # -----------------------------------------------------
    expected_dt_sec: float = 0.1          # 기대 샘플링 간격(초)

    # -----------------------------------------------------
    # 1-3. 분석 기능 ON / OFF
    # 현재는 틀만 유지, 실제 구현은 이후 단계에서 진행
    # -----------------------------------------------------
    run_timebase_qa: bool = True
    run_depth_qc: bool = True
    run_detrend: bool = True
    run_wave_detection: bool = True
    run_time_domain_stats: bool = True
    run_spectral_stats: bool = False
    run_swell_partition: bool = False
    run_ig_analysis: bool = False
    run_event_detection: bool = False

    # -----------------------------------------------------
    # 1-4. 출력 관련
    # -----------------------------------------------------
    output_root: str = "outputs"          # 결과 저장 루트 폴더
    save_csv: bool = True
    save_plot: bool = True
    save_excluded_raw_txt: bool = True     # 처리 제외 raw 행 텍스트 저장 ON/OFF
    excluded_raw_txt_name: str = "excluded_raw_rows.txt"


