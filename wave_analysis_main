def save_excluded_rows_txt(excluded_df: pd.DataFrame, out_dir: Path, filename: str) -> Path:
    """
    처리 제외된 raw 행을 텍스트(.txt)로 저장한다.
    """
    output_path = out_dir / filename

    if excluded_df.empty:
        with open(output_path, "w", encoding="utf-8") as f:
            f.write("[INFO] 처리 제외된 행이 없습니다.\n")
        return output_path

    export_df = excluded_df.copy()
    if "analysis_time" in export_df.columns:
        export_df["analysis_time"] = export_df["analysis_time"].astype(str)

    preferred_cols = [
        "raw_row_index",
        "analysis_time",
        "exclusion_reason",
        "exclusion_reason_count",
        "excluded_by_invalid_time",
        "excluded_by_duplicate_time",
        "excluded_by_invalid_depth",
        "time_local",
        "depth_m",
    ]
    existing_preferred = [c for c in preferred_cols if c in export_df.columns]
    remaining_cols = [c for c in export_df.columns if c not in existing_preferred]
    export_df = export_df[existing_preferred + remaining_cols]

    sort_cols = [c for c in ["analysis_time", "time_local"] if c in export_df.columns]
    if sort_cols:
        export_df = export_df.sort_values(by=sort_cols)
    export_df.to_csv(output_path, index=False, encoding="utf-8-sig")
    return output_path


def plot_depth_qc_review(df: pd.DataFrame, out_dir: Path, cfg: Config, qc_meta: Dict) -> Dict:
    """
    Depth QC 검증용 시각화/진단 모듈

    현재 구현
    - 탐지 후보가 있을 때만 review plot 생성
    - 우선순위: jump_recover > slope > isolated_spikes > hampel > union
    - 같은 종류 내 대표성(밀집도/크기/지속시간) 기반으로 우선 선택
    """
    review_meta = {
        "selected_segments": [],
        "saved_plots": [],
        "extrema_flag_ratio": qc_meta.get("extrema_flag_ratio"),
        "selected_plots_total": 0,
        "selected_jump_recover": 0,
        "selected_slope": 0,
        "selected_isolated_spikes": 0,
        "selected_hampel": 0,
        "selected_union": 0,
    }

    if not cfg.save_plot:
        return review_meta

    if cfg.depth_col not in df.columns:
        return review_meta

    # -----------------------------------------------------
    # 1) 마스크 준비
    # -----------------------------------------------------
    hampel_mask = df.get("depth_flag_hampel", False).astype(bool)
    slope_mask = df.get("depth_flag_slope", False).astype(bool)
    jump_recover_mask = df.get("depth_flag_jump_recover", False).astype(bool)
    spike_mask = df.get("depth_flag_spike", False).astype(bool)

    union_mask = hampel_mask | slope_mask
    isolated_spike_mask = spike_mask & (~jump_recover_mask) & (~df.get("depth_flag_bad_segment", False).astype(bool))

    # 후보가 없으면 생성하지 않음
    if not (union_mask.any() or jump_recover_mask.any() or isolated_spike_mask.any()):
        return review_meta

    dt = float(cfg.expected_dt_sec)
    if "analysis_time" in df.columns and len(df) >= 2:
        dt_series = df["analysis_time"].sort_values().diff().dt.total_seconds().dropna()
        dt_series = dt_series[dt_series > 0]
        if not dt_series.empty:
            dt = float(dt_series.median())

    window_n = max(5, int(round(10.0 / dt)))

    def build_candidates(mask: pd.Series, criterion: str, max_candidates: int = 40):
        if not mask.any():
            return []

        density = mask.astype(int).rolling(window=window_n, center=True, min_periods=1).sum()
        centers = density.sort_values(ascending=False).index.tolist()

        candidates = []
        used = []
        for c in centers:
            if len(candidates) >= max_candidates:
                break
            c = int(c)
            if any(abs(c - u) < window_n for u in used):
                continue

            s_idx = max(0, c - window_n // 2)
            e_idx = min(len(df) - 1, c + window_n // 2)

            part_mask = mask.iloc[s_idx:e_idx + 1]
            if not part_mask.any():
                continue

            # 대표성 점수: 밀집도 + depth 변화 크기 + 시간 지속 길이
            density_score = int(part_mask.sum())
            y = pd.to_numeric(df.iloc[s_idx:e_idx + 1][cfg.depth_col], errors="coerce")
            mag_score = float((y.max() - y.min())) if y.notna().any() else 0.0

            if "analysis_time" in df.columns:
                t0 = df.iloc[s_idx]["analysis_time"]
                t1 = df.iloc[e_idx]["analysis_time"]
                duration_score = float((t1 - t0).total_seconds())
            else:
                duration_score = float((e_idx - s_idx) * dt)

            score = density_score * 10.0 + mag_score + duration_score
            candidates.append(
                {
                    "start_index": int(s_idx),
                    "end_index": int(e_idx),
                    "label": criterion,
                    "score": float(score),
                }
            )
            used.append(c)

        return candidates

    # -----------------------------------------------------
    # 2) 우선순위 기반 후보 구성
    # -----------------------------------------------------
    cand_jump = build_candidates(jump_recover_mask, "jump_recover")
    cand_slope = build_candidates(slope_mask, "slope")
    cand_isolated = build_candidates(isolated_spike_mask, "isolated_spikes")
    cand_hampel = build_candidates(hampel_mask, "hampel")
    cand_union = build_candidates(union_mask, "union")

    priority_buckets = [
        ("jump_recover", cand_jump),
        ("slope", cand_slope),
        ("isolated_spikes", cand_isolated),
        ("hampel", cand_hampel),
        ("union", cand_union),
    ]

    selected = []
    occupied = []
    max_plots = 10

    for criterion, bucket in priority_buckets:
        if len(selected) >= max_plots:
            break

        bucket = sorted(bucket, key=lambda x: x["score"], reverse=True)
        for seg in bucket:
            if len(selected) >= max_plots:
                break

            s_idx = int(seg["start_index"])
            e_idx = int(seg["end_index"])
            if any(not (e_idx < os or s_idx > oe) for os, oe in occupied):
                continue

            selected.append(seg)
            occupied.append((s_idx, e_idx))

    review_meta["selected_segments"] = selected

    # -----------------------------------------------------
    # 3) 구간별 그래프 저장
    # -----------------------------------------------------
    bad_mask = (~df.get("analysis_mask_time_domain", True)).astype(bool)

    for i, seg in enumerate(selected, start=1):
        s_idx = int(seg["start_index"])
        e_idx = int(seg["end_index"])
        criterion = seg["label"]

        part = df.iloc[s_idx:e_idx + 1].copy()
        if part.empty:
            continue

        x = part["analysis_time"] if "analysis_time" in part.columns else part.index
        y = pd.to_numeric(part[cfg.depth_col], errors="coerce")

        fig, ax = plt.subplots(figsize=(12, 4))
        ax.plot(x, y, color="black", linewidth=1.0, label="raw depth_m")

        local_hampel = hampel_mask.iloc[s_idx:e_idx + 1].values
        local_slope = slope_mask.iloc[s_idx:e_idx + 1].values
        local_jump_recover = jump_recover_mask.iloc[s_idx:e_idx + 1].values

        local_hampel_only = local_hampel & (~local_slope)
        local_slope_only = local_slope & (~local_hampel)
        local_overlap = local_hampel & local_slope

        part_hampel_only = part[local_hampel_only]
        if not part_hampel_only.empty:
            xh = part_hampel_only["analysis_time"] if "analysis_time" in part_hampel_only.columns else part_hampel_only.index
            yh = pd.to_numeric(part_hampel_only[cfg.depth_col], errors="coerce")
            ax.scatter(xh, yh, color="red", marker="o", s=22, label="hampel-only", zorder=5)

        part_slope_only = part[local_slope_only]
        if not part_slope_only.empty:
            xs = part_slope_only["analysis_time"] if "analysis_time" in part_slope_only.columns else part_slope_only.index
            ys = pd.to_numeric(part_slope_only[cfg.depth_col], errors="coerce")
            ax.scatter(xs, ys, color="blue", marker="x", s=28, label="slope-only", zorder=5)

        part_overlap = part[local_overlap]
        if not part_overlap.empty:
            xo = part_overlap["analysis_time"] if "analysis_time" in part_overlap.columns else part_overlap.index
            yo = pd.to_numeric(part_overlap[cfg.depth_col], errors="coerce")
            ax.scatter(xo, yo, color="purple", marker="D", s=24, label="hampel+slope overlap", zorder=6)

        part_jump = part[local_jump_recover]
        if not part_jump.empty:
            xj = part_jump["analysis_time"] if "analysis_time" in part_jump.columns else part_jump.index
            yj = pd.to_numeric(part_jump[cfg.depth_col], errors="coerce")
            ax.scatter(xj, yj, color="gold", edgecolor="black", marker="*", s=80, label="jump_recover_spike", zorder=7)

        local_bad = bad_mask.iloc[s_idx:e_idx + 1].reset_index(drop=True)
        if local_bad.any():
            rid = (local_bad != local_bad.shift(1, fill_value=False)).cumsum()
            for _, grp in local_bad[local_bad].groupby(rid[local_bad]):
                gs = grp.index.min()
                ge = grp.index.max()
                x0 = x.iloc[gs]
                x1 = x.iloc[ge]
                ax.axvspan(x0, x1, color="orange", alpha=0.25, label="analysis_mask_time_domain=False")

        ax.set_title(f"Depth QC Review #{i} [{criterion}]")
        ax.set_xlabel("time")
        ax.set_ylabel("depth_m")
        handles, labels = ax.get_legend_handles_labels()
        by_label = dict(zip(labels, handles))
        ax.legend(by_label.values(), by_label.keys(), loc="best")
        ax.grid(alpha=0.3)

        output_path = out_dir / f"depth_qc_review_{i:02d}_{criterion}.png"
        fig.tight_layout()
        fig.savefig(output_path, dpi=150)
        plt.close(fig)

        review_meta["saved_plots"].append(str(output_path))

    # -----------------------------------------------------
    # 4) 선택 결과 메타 집계
    # -----------------------------------------------------
    selected_labels = [seg.get("label") for seg in selected]
    review_meta["selected_plots_total"] = int(len(selected_labels))
    review_meta["selected_jump_recover"] = int(sum(1 for x in selected_labels if x == "jump_recover"))
    review_meta["selected_slope"] = int(sum(1 for x in selected_labels if x == "slope"))
    review_meta["selected_isolated_spikes"] = int(sum(1 for x in selected_labels if x == "isolated_spikes"))
    review_meta["selected_hampel"] = int(sum(1 for x in selected_labels if x == "hampel"))
    review_meta["selected_union"] = int(sum(1 for x in selected_labels if x == "union"))

    return review_meta


def plot_detrend_review(df: pd.DataFrame, out_dir: Path, cfg: Config) -> Dict:
    """
    Detrend 검증용 시각화

    생성 그래프
    - 짧은 구간 확대: depth / eta_short / eta_ig
    - 전체 구간: eta_tide
    """
    review_meta = {
        "saved_plots": [],
    }

    if not cfg.save_plot:
        return review_meta

    required_cols = [cfg.depth_col, "eta_short", "eta_ig", "eta_tide"]
    if any(col not in df.columns for col in required_cols):
        return review_meta

    x = df["analysis_time"] if "analysis_time" in df.columns else df.index

    # 1) 짧은 구간 확대
    dt_sec = float(cfg.expected_dt_sec)
    if "analysis_time" in df.columns and len(df) >= 2:
        dt = df["analysis_time"].diff().dt.total_seconds()
        dt = dt[(dt > 0) & dt.notna()]
        if not dt.empty:
            dt_sec = float(dt.median())
    zoom_n = max(100, int(round(180.0 / dt_sec)))
    zoom_n = min(zoom_n, len(df))

    fig, ax = plt.subplots(3, 1, figsize=(12, 8), sharex=True)
    ax[0].plot(x.iloc[:zoom_n] if hasattr(x, "iloc") else x[:zoom_n], df[cfg.depth_col].iloc[:zoom_n], color="black", linewidth=0.9)
    ax[0].set_ylabel("depth")
    ax[0].grid(alpha=0.3)

    ax[1].plot(x.iloc[:zoom_n] if hasattr(x, "iloc") else x[:zoom_n], df["eta_short"].iloc[:zoom_n], color="tab:blue", linewidth=0.9)
    ax[1].set_ylabel("eta_short")
    ax[1].grid(alpha=0.3)

    ax[2].plot(x.iloc[:zoom_n] if hasattr(x, "iloc") else x[:zoom_n], df["eta_ig"].iloc[:zoom_n], color="tab:green", linewidth=0.9)
    ax[2].set_ylabel("eta_ig")
    ax[2].grid(alpha=0.3)
    ax[2].set_xlabel("time")

    fig.suptitle("Detrend Review (Zoom): depth / eta_short / eta_ig")
    fig.tight_layout()
    zoom_path = out_dir / "detrend_review_zoom.png"
    fig.savefig(zoom_path, dpi=150)
    plt.close(fig)
    review_meta["saved_plots"].append(str(zoom_path))

    # 2) 전체 eta_tide
    fig, ax = plt.subplots(figsize=(12, 3.5))
    ax.plot(x, df["eta_tide"], color="tab:orange", linewidth=0.8)
    ax.set_title("Detrend Review (Full): eta_tide")
    ax.set_ylabel("eta_tide")
    ax.set_xlabel("time")
    ax.grid(alpha=0.3)
    fig.tight_layout()
    tide_path = out_dir / "detrend_review_eta_tide_full.png"
    fig.savefig(tide_path, dpi=150)
    plt.close(fig)
    review_meta["saved_plots"].append(str(tide_path))

    return review_meta

