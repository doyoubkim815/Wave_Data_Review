def prompt_input_file() -> Path:
    """
    터미널에서 분석 대상 파일 경로를 입력받는다.

    지원 형식
    - .csv
    - .xlsx
    - .xls
    """
    print("분석할 raw 데이터 파일 경로를 입력하십시오.")
    print("지원 형식: .csv, .xlsx, .xls")

    input_path = input("File path: ").strip().strip('"').strip("'")

    if not input_path:
        raise ValueError("파일 경로가 입력되지 않았습니다.")

    file_path = Path(input_path).expanduser()

    if not file_path.exists():
        raise FileNotFoundError(f"파일을 찾을 수 없습니다: {file_path}")

    if file_path.suffix.lower() not in [".csv", ".xlsx", ".xls"]:
        raise ValueError(f"지원하지 않는 파일 형식입니다: {file_path.suffix}")

    return file_path


def load_input_file(file_path: Path, cfg: Config, out_dir: Optional[Path] = None) -> Tuple[pd.DataFrame, Dict]:
    """
    입력 파일을 읽고, 컬럼명 정규화 및 시간축 생성까지 수행한다.

    반환
    - df   : 전처리된 DataFrame
    - meta : 파일 로드 및 시간축 생성 관련 메타정보
    """
    # -----------------------------------------------------
    # 1) 파일 읽기
    # -----------------------------------------------------
    if file_path.suffix.lower() == ".csv":
        df = pd.read_csv(file_path)
    else:
        df = pd.read_excel(file_path)

    raw_n_rows = len(df)
    raw_columns = list(df.columns)

    # -----------------------------------------------------
    # 2) 컬럼명 정규화
    # -----------------------------------------------------
    df = normalize_columns(df)

    # -----------------------------------------------------
    # 3) 공통 시간축 생성
    # -----------------------------------------------------
    df, time_meta, excluded_rows_df = ensure_time_axis(df, cfg)

    if cfg.save_excluded_raw_txt and out_dir is not None:
        excluded_txt_path = save_excluded_rows_txt(
            excluded_rows_df,
            out_dir,
            cfg.excluded_raw_txt_name,
        )
        time_meta["excluded_raw_txt"] = str(excluded_txt_path)

    # -----------------------------------------------------
    # 4) 로드 메타정보 정리
    # -----------------------------------------------------
    meta = {
        "input_file": str(file_path),
        "raw_n_rows": int(raw_n_rows),
        "processed_n_rows": int(len(df)),
        "raw_columns": raw_columns,
        "normalized_columns": list(df.columns),
        **time_meta,
    }

    return df, meta


