            print(f"    - analysis_time 중복으로 제외: {dropped_duplicate_time}")
            print(f"    - depth_m 결측 또는 0.0(미계측)으로 제외: {dropped_invalid_depth}")
            print(f"    - 복수 사유 동시 해당 행 수: {excluded_multi_reason}")

        excluded_txt = load_meta.get("excluded_raw_txt")
        if excluded_txt:
            print(f"- 처리 제외 raw 행 파일(.txt): {excluded_txt}")

        qa_meta = results.meta.get("timebase_qa", {})
        if qa_meta:
            print("- 시간축 QA 요약(post-clean):")
            print(f"  · expected dt (sec): {qa_meta.get('post_clean_expected_dt_sec')}")
            print(f"  · n_rows / n_intervals: {qa_meta.get('post_clean_n_rows')} / {qa_meta.get('post_clean_n_intervals')}")
            print(f"  · dt mean/median (sec): {qa_meta.get('post_clean_dt_mean_sec')} / {qa_meta.get('post_clean_dt_median_sec')}")
            print(f"  · dt min/max (sec): {qa_meta.get('post_clean_dt_min_sec')} / {qa_meta.get('post_clean_dt_max_sec')}")
            print(f"  · |dt-expected| mean/max (sec): {qa_meta.get('post_clean_dt_abs_diff_mean_sec')} / {qa_meta.get('post_clean_dt_abs_diff_max_sec')}")
            print(f"  · gap intervals: {qa_meta.get('post_clean_n_gap_intervals')}")
            print(f"  · duplicate intervals(dt=0): {qa_meta.get('post_clean_n_duplicate_intervals')}")

        gap_meta = results.meta.get("gap_handling", {})
        if gap_meta:
            print("- Gap Handling 요약:")
            print(f"  · short gap count (dt<=0.3s): {gap_meta.get('short_gap_count')}")
            print(f"  · long gap count  (dt>0.3s): {gap_meta.get('long_gap_count')}")

        print("- 현재 단계에서는 파일 로드, 시간축 표준화, timebase_qa, gap_handling까지 수행했습니다.")
