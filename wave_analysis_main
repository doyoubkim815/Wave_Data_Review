def run_pipeline(file_path: Path, cfg: Config, out_dir: Path) -> AnalysisResults:
    """
    전체 분석 파이프라인 실행 함수

    현재 단계에서는
    - 파일 로드
    - 컬럼 정규화
    - time_local 기반 시간축 생성
    - load_input 메타정보 기록
까지만 수행한다.

    이후 단계에서는 기존 구조를 유지한 채 아래를 순차 추가한다.
    - run_timebase_qa
    - run_depth_qc
    - run_detrend
    - detect_individual_waves
    - compute_time_domain_stats
    - compute_spectral_stats
    - ...
    """
    results = AnalysisResults()

    # -----------------------------------------------------
    # 1) 입력 파일 로드
    # -----------------------------------------------------
    df, load_meta = load_input_file(file_path, cfg, out_dir)
    log_meta(results, "load_input", load_meta)

    # -----------------------------------------------------
    # 2) 이후 단계에서 아래 순서를 그대로 유지하며 기능 추가
    # 구조를 바꾸지 않고 각 함수 내부만 채워 넣는 것이 원칙
    # -----------------------------------------------------
    if cfg.run_timebase_qa:
        df, meta = run_timebase_qa(df, cfg)
        results.qa = meta
        log_meta(results, "timebase_qa", meta)

        df, gap_meta = run_gap_handling(df, cfg, meta)
        log_meta(results, "gap_handling", gap_meta)

    if cfg.run_depth_qc:
        df, meta = run_depth_qc(df, cfg)
        results.qc = meta
        log_meta(results, "depth_qc", meta)

        df, policy_meta = apply_depth_exclusion_policy(df, cfg, meta)
        log_meta(results, "depth_exclusion_policy", policy_meta)

        review_meta = plot_depth_qc_review(df, out_dir, cfg, meta)
        log_meta(results, "depth_qc_review", review_meta)

    if cfg.run_detrend:
        df, meta = run_detrend(df, cfg)
        log_meta(results, "detrend", meta)

        detrend_review_meta = plot_detrend_review(df, out_dir, cfg)
        log_meta(results, "detrend_review", detrend_review_meta)

        if cfg.save_decomposed_series_csv:
            out_cols = ["analysis_time", cfg.depth_col, "eta_centered", "eta_tide", "eta_detrended", "eta_short", "eta_ig"]
            out_cols = [c for c in out_cols if c in df.columns]
            save_table(df[out_cols], out_dir, "decomposed_series.csv")
            results.meta.setdefault("detrend", {})["decomposed_series_csv"] = str(out_dir / "decomposed_series.csv")
    #
    # if cfg.run_wave_detection:
    #     waves_df, meta = detect_individual_waves(df, cfg)
    #     log_meta(results, "wave_detection", meta)
    #
    # if cfg.run_time_domain_stats:
    #     td_df, meta = compute_time_domain_stats(waves_df, cfg)
    #     results.td_stats = td_df
    #     log_meta(results, "time_domain_stats", meta)

    return results


