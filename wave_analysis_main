@dataclass
class Config:
    """
    사용자 설정값 모음

    원칙
    - 향후 제어변수는 모두 이 클래스에만 추가
    - 함수 내부에 하드코딩하지 않음
    """

    # -----------------------------------------------------
    # 1-1. 입력 파일 표준 컬럼명
    # -----------------------------------------------------
    time_col: str = "time_local"          # 주 분석 시간축 컬럼
    depth_col: str = "depth_m"            # 수면 높이 또는 수심 계측값
    wind_dir_col: str = "wind_dir_deg"    # 풍향 (현재는 읽기만 함)
    wind_speed_col: str = "wind_speed"    # 풍속 (현재는 읽기만 함)

    # -----------------------------------------------------
    # 1-2. 샘플링 관련
    # -----------------------------------------------------
    expected_dt_sec: float = 0.1          # 기대 샘플링 간격(초)

    # depth QC 파라미터
    depth_qc_method: str = "hampel"
    depth_qc_window_sec: float = 6.0
    depth_qc_n_sigma: float = 8.0
    depth_qc_max_slope_mps: float = 3.0

    # detrend 파라미터
    detrend_tide_cutoff_sec: float = 1800.0
    detrend_short_band_sec: Tuple[float, float] = (2.0, 25.0)
    detrend_ig_band_sec: Tuple[float, float] = (25.0, 300.0)
    detrend_zero_phase: bool = True

    # depth 제외 정책 스위치
    exclude_jump_recover_candidates: bool = False
    exclude_bad_segments: bool = False
    exclude_isolated_spikes: bool = False

    # -----------------------------------------------------
    # 1-3. 분석 기능 ON / OFF
    # 현재는 틀만 유지, 실제 구현은 이후 단계에서 진행
    # -----------------------------------------------------
    run_timebase_qa: bool = True
    run_depth_qc: bool = True
    run_detrend: bool = True
    run_wave_detection: bool = True
    run_time_domain_stats: bool = True
    run_spectral_stats: bool = False
    run_swell_partition: bool = False
    run_ig_analysis: bool = False
    run_event_detection: bool = False

    # -----------------------------------------------------
    # 1-4. 출력 관련
    # -----------------------------------------------------
    output_root: str = "outputs"          # 결과 저장 루트 폴더
    save_csv: bool = True
    save_plot: bool = True
    save_excluded_raw_txt: bool = True     # 처리 제외 raw 행 텍스트 저장 ON/OFF
    excluded_raw_txt_name: str = "excluded_raw_rows.txt"
    save_decomposed_series_csv: bool = False


