#!/usr/bin/env python3
# -*- coding: utf-8 -*-

"""
파고계 기반 파랑 분석 프레임워크 (기준 골격 v1)

목적
- csv / xlsx raw 데이터에서 파랑 분석을 단계적으로 확장하기 위한 단일 파일 골격
- 기능을 한 번에 다 넣지 않고, 이후 대화 또는 Codex를 통해 분석 항목을 하나씩 추가
- 코드 구조를 고정하여 추후 수정/추가 시 전체 형태가 흔들리지 않도록 함

현재 구현 범위
1) 입력 파일 경로 받기
2) csv / xlsx 파일 읽기
3) 컬럼명 정규화
4) time_local 기반 공통 시간축 생성
5) 출력 폴더 생성
6) metadata 저장

향후 추가 예정
- 시간축 QA (dt, gap, duplicate, missing)
- depth 이상치 제거(QC / despike)
- 기준수면 제거(detrend)
- 개별 파 검출(zero-crossing)
- Hs / Hmax / Tz sliding window 통계
- Hm0 / Tp / Tm01 / Tm02
- Sea / Swell 분리
- 장주기파(IG) 지표
- 이벤트 탐지
- 예보 비교 및 성능 평가
"""

# =========================================================
# 0. Imports
# =========================================================
import json
from pathlib import Path
from dataclasses import dataclass, field
from typing import Dict, Optional, Tuple

import matplotlib.pyplot as plt
